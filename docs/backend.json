
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a single user account in Firebase Authentication.",
      "properties": {
        "id": { "type": "string", "description": "The user's Firebase Auth UID." },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "companyId": { "type": ["string", "null"], "description": "The ID of the company this user belongs to in the /companies collection. Null for partners." },
        "role": { "type": "string", "enum": ["owner", "staff", "partner"], "description": "The user's role in the system." },
        "passwordChangeRequired": { "type": "boolean", "description": "If true, the user must change their password on next login." },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "Company": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Company",
      "type": "object",
      "description": "Represents a member's business entity on the TransConnect platform.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the company." },
        "ownerId": { "type": "string", "description": "The Firebase Auth UID of the user who owns and manages this company account." },
        "companyName": { "type": "string", "description": "The registered business name of the company." },
        "registrationNumber": { "type": "string" },
        "vatNumber": { "type": "string" },
        "streetAddress": { "type": "string" },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "postalCode": { "type": "string" },
        "bankName": { "type": "string" },
        "branchCode": { "type": "string" },
        "accountNumber": { "type": "string" },
        "accountHolderName": { "type": "string" },
        "membershipId": { "type": "string", "description": "Reference to Membership tier ID." },
        "membershipStartDate": { "type": "string", "format": "date-time" },
        "billingCycle": { "type": "string", "enum": ["monthly", "annual"] },
        "nextBillingDate": { "type": "string", "format": "date-time" },
        "shopId": { "type": "string", "description": "The ID of the shop owned by this company." },
        "rewardPoints": { "type": "number", "description": "Points earned for community actions." },
        "walletBalance": { "type": "number", "description": "Total ledger balance, including pending funds." },
        "pendingBalance": { "type": "number", "description": "Funds from recent sales not yet cleared for withdrawal." },
        "availableBalance": { "type": "number", "description": "Funds cleared and available for withdrawal or purchases." },
        "loyaltyTier": { "type": "string", "enum": ["bronze", "silver", "gold"], "description": "The current loyalty status of the member." },
        "activePlans": { "type": "array", "items": { "type": "string" }, "description": "A list of activated Connect plans (e.g., 'loyalty', 'rewards')." },
        "isBillable": { "type": "boolean", "description": "Flag to indicate if the company has an active, billable subscription." },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "ownerId", "companyName", "membershipId"]
    },
    "Partner": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Partner",
      "type": "object",
      "description": "Represents a strategic partner, Independent Sales Agent (ISA), Investor, or Developer in the system.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "companyName": { "type": "string", "description": "The name of the partner's own company." },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "The operational status of the partnership." },
        "invitationStatus": { "type": "string", "enum": ["pending", "invited", "registered"], "description": "The status of their invitation to join the platform." },
        "type": { "type": "string", "enum": ["partner", "isa", "investor", "developer"], "description": "The type of partner, e.g., a strategic Partner, ISA, Investor, or Developer." },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["firstName", "lastName", "email"]
    },
    "Shop": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Shop",
      "type": "object",
      "description": "Represents a vendor's shop on the TransConnect platform.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the shop." },
        "ownerId": { "type": "string" },
        "companyId": { "type": "string" },
        "shopName": { "type": "string" },
        "shopDescription": { "type": "string" },
        "category": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "contactPhone": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "pending_review", "approved", "rejected"] },
        "theme": { "type": "string", "enum": ["forest-green", "ocean-blue", "industrial-grey", "sunset-orange"], "description": "The color theme for the shop's public page." },
        "template": { "type": "string", "enum": ["classic-grid", "classic-list"], "description": "The layout template for the product list." },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "heroBannerUrl": { "type": "string" },
        "facebookLink": { "type": "string", "format": "uri", "description": "URL to the shop's Facebook page." },
        "instagramLink": { "type": "string", "format": "uri", "description": "URL to the shop's Instagram profile." },
        "twitterLink": { "type": "string", "format": "uri", "description": "URL to the shop's Twitter (X) profile." },
        "linkedinLink": { "type": "string", "format": "uri", "description": "URL to the shop's LinkedIn page." },
        "youtubeLink": { "type": "string", "format": "uri", "description": "URL to the shop's YouTube channel." },
        "termsUrl": { "type": "string", "description": "URL to the shop's terms and conditions PDF." },
        "returnsPolicyUrl": { "type": "string", "description": "URL to the shop's return policy PDF." },
        "privacyPolicyUrl": { "type": "string", "description": "URL to the shop's privacy policy PDF." },
        "promotions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "imageUrl": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "ownerId", "companyId", "shopName", "category", "status"]
    },
    "CommercialAgreement": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Commercial Agreement",
        "type": "object",
        "description": "Represents a versioned commercial agreement for a shop.",
        "properties": {
            "id": { "type": "string" },
            "percentage": { "type": "number", "description": "The platform commission percentage for this agreement." },
            "status": { "type": "string", "enum": ["proposed", "active", "archived"], "description": "The status of the agreement." },
            "effectiveDate": { "type": "string", "format": "date-time", "description": "The date this agreement becomes active." },
            "acceptedBy": { "type": "string", "description": "The UID of the user who accepted the agreement." },
            "proposedBy": { "type": "string", "description": "The UID of the user who proposed the agreement." },
            "expiryDate": { "type": "string", "format": "date-time", "description": "Optional: The date this agreement expires." },
            "volumeThreshold": { "type": "number", "description": "Optional: The sales volume threshold for this agreement to apply." },
            "createdAt": { "type": "object" },
            "updatedAt": { "type": "object" }
        },
        "required": ["id", "percentage", "status", "effectiveDate", "proposedBy"]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a single product within a vendor's shop.",
      "properties": {
        "shopId": { "type": "string" },
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "sku": { "type": "string" },
        "stock": { "type": "number", "description": "Number of units available in stock." },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["shopId", "companyId", "name", "price"]
    },
    "Staff": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Staff",
      "type": "object",
      "description": "Represents a staff member associated with a company.",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "title": { "type": "string", "description": "The official job title of the staff member." },
        "role": { "type": "string", "description": "The assigned permission role (e.g., admin, user)." },
        "function": { "type": "string", "description": "The primary task-based function of the staff member." },
        "jobDescription": { "type": "string", "description": "A brief description of the staff member's responsibilities." },
        "companyId": { "type": "string", "description": "The ID of the parent company this staff member belongs to." },
        "status": { "type": "string", "enum": ["confirmed", "unconfirmed"], "description": "The confirmation status of the staff member." },
        "permissions": { "type": "array", "items": { "type": "string"}, "description": "List of resource:action permissions assigned directly to this staff member." },
        "createdAt": { "type": "object" }
      },
      "required": ["firstName", "lastName", "email", "title", "role", "companyId"]
    },
    "Permission": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Permission",
      "type": "object",
      "description": "Represents a single granular permission in the system.",
      "properties": {
        "id": { "type": "string", "description": "e.g., 'shop:edit'" },
        "name": { "type": "string", "description": "e.g., 'Can Edit Shop'" },
        "description": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Role": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Role",
      "type": "object",
      "description": "A collection of permissions that can be assigned to a staff member.",
      "properties": {
        "id": { "type": "string", "description": "e.g., 'shop_manager'" },
        "name": { "type": "string", "description": "e.g., 'Shop Manager'" },
        "permissions": { "type": "array", "items": { "type": "string" }, "description": "List of permission IDs." }
      },
      "required": ["id", "name"]
    },
    "Function": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Function",
      "type": "object",
      "description": "A task-based grouping of permissions.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name"]
    },
    "Membership": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Membership",
      "type": "object",
      "description": "Represents a single tier of membership plan.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number", "description": "The base monthly price of the plan." },
        "annualDiscount": { "type": "number", "description": "The discount percentage applied when a member chooses an annual subscription." },
        "specialOfferText": { "type": "string", "description": "Promotional text for the special offer." },
        "specialOfferDiscount": { "type": "number", "description": "A temporary promotional discount percentage." },
        "specialOfferStartDate": { "type": "string", "format": "date-time", "description": "The start date for the special offer." },
        "specialOfferEndDate": { "type": "string", "format": "date-time", "description": "The end date for the special offer." },
        "features": { "type": "array", "items": { "type": "string" } },
        "isPopular": { "type": "boolean" },
        "version": { "type": "number", "description": "A version number for tracking changes to the plan." }
      },
      "required": ["id", "name", "description"]
    },
     "ConnectPlanDetail": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Connect Plan Detail",
        "type": "object",
        "description": "Represents the pricing and offer details for a single Connect plan.",
        "properties": {
            "price": { "type": "number" },
            "specialOfferText": { "type": "string", "description": "Promotional text for the special offer." },
            "specialOfferDiscount": { "type": "number", "description": "The discount percentage for the special offer." },
            "specialOfferStartDate": { "type": "string", "format": "date-time", "description": "The start date for the special offer." },
            "specialOfferEndDate": { "type": "string", "format": "date-time", "description": "The end date for the special offer." }
        },
        "required": ["price"]
    },
    "ConnectPlans": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Connect Plans Configuration",
        "type": "object",
        "description": "Configuration for all Connect plans (Loyalty, Rewards, Actions).",
        "properties": {
            "loyalty": { "$ref": "#/entities/ConnectPlanDetail" },
            "rewards": { "$ref": "#/entities/ConnectPlanDetail" },
            "actions": { "$ref": "#/entities/ConnectPlanDetail" }
        }
    },
    "Contribution": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Contribution",
      "type": "object",
      "description": "Represents a single data contribution from a user.",
      "properties": {
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
        "type": { "type": "string", "enum": ["truck", "trailer", "supplier", "client"] },
        "data": { "type": "object" },
        "createdAt": { "type": "object" }
      },
      "required": ["userId", "companyId", "type", "data", "createdAt"]
    },
    "Quote": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Quote",
      "type": "object",
      "description": "Represents a funding quote generated by a user.",
      "properties": {
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
        "fundingType": { "type": "string" },
        "amountRequested": { "type": "number" },
        "details": { "type": "object" },
        "createdAt": { "type": "object" }
      }
    },
    "Enquiry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Enquiry",
      "type": "object",
      "description": "Represents a formal funding enquiry submitted by a user.",
      "properties": {
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
        "status": { "type": "string" },
        "fundingType": { "type": "string" },
        "amountRequested": { "type": "number" },
        "purpose": { "type": "string" },
        "createdAt": { "type": "object" }
      }
    },
    "WalletPayment": {
       "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WalletPayment",
      "type": "object",
      "description": "Represents a pending wallet top-up or membership payment.",
      "properties": {
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "createdAt": { "type": "object" }
      }
    },
     "PayoutRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PayoutRequest",
      "type": "object",
      "description": "Represents a request from a member to withdraw funds from their wallet.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "rejected"] },
        "createdAt": { "type": "object" },
        "processedAt": { "type": "object" },
        "rejectionReason": { "type": "string" }
      },
      "required": ["id", "userId", "companyId", "amount", "status", "createdAt"]
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Represents a single financial transaction in the company's wallet ledger.",
      "properties": {
        "transactionId": { "type": "string" },
        "reconciliationId": { "type": "string" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "chartOfAccountsCode": { "type": "string" },
        "status": { "type": "string", "enum": ["pending_allocation", "allocated", "reversal"] },
        "isAdjustment": { "type": "boolean" }
      },
      "required": ["transactionId", "type", "amount", "date", "description", "status"]
    },
    "Reconciliation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Reconciliation",
      "type": "object",
      "description": "Represents a single bank statement reconciliation batch.",
      "properties": {
        "id": { "type": "string" },
        "statementPeriod": { "type": "string" },
        "openingBalance": { "type": "number" },
        "closingBalance": { "type": "number" },
        "status": { "type": "string", "enum": ["in_progress", "completed"] },
        "processedAt": { "type": "object" }
      },
      "required": ["id", "statementPeriod", "openingBalance", "status"]
    },
    "Reward": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Reward",
      "type": "object",
      "description": "A redeemable reward in the loyalty program.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "pointsCost": { "type": "number" },
        "type": { "type": "string", "enum": ["voucher", "discount", "product"] },
        "isActive": { "type": "boolean" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "title", "pointsCost", "type", "isActive"]
    },
    "Lead": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Lead",
        "type": "object",
        "description": "Represents a potential business lead generated by the system.",
        "properties": {
            "id": { "type": "string" },
            "companyName": { "type": "string" },
            "contactPerson": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" },
            "role": { "type": "string" },
            "status": { "type": "string", "enum": ["new", "contacted", "qualified", "unqualified"] },
            "notes": { "type": "string" },
            "address": { "type": "string" },
            "website": { "type": "string" },
            "createdAt": { "type": "object" },
            "updatedAt": { "type": "object" }
        },
        "required": ["companyName", "role", "status"]
    },
    "AuditLog": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Audit Log",
        "type": "object",
        "description": "Records a change made to a Firestore document by an authenticated user or admin.",
        "properties": {
            "id": { "type": "string" },
            "collectionPath": { "type": "string" },
            "documentId": { "type": "string" },
            "userId": { "type": "string", "description": "UID of the user who performed the action." },
            "action": { "type": "string", "enum": ["create", "update", "delete"] },
            "timestamp": { "type": "object" },
            "before": { "type": "object", "description": "State of the document before the change." },
            "after": { "type": "object", "description": "State of the document after the change." }
        },
        "required": ["collectionPath", "documentId", "userId", "action", "timestamp"]
    },
    "Client": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Client",
        "description": "Represents a debtor entity in the lending system.",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "status": { "type": "string" },
            "globalFacilityLimit": { "type": "number", "description": "The maximum total exposure allowed for this client across all facilities." }
        }
    },
    "Agreement": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Agreement",
        "description": "Represents a single lending agreement with a client.",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "clientId": { "type": "string", "description": "The ID of the client this agreement belongs to."},
            "assetId": { "type": "string", "description": "The ID of the asset being financed under this agreement."},
            "type": { "type": "string", "enum": ["loan-pv", "loan-fl", "installment-sale", "rental", "discounting"], "description": "The type of lending agreement."},
            "status": { "type": "string", "enum": ["pending", "active", "completed", "defaulted"], "description": "The current status of the agreement."},
            "amount": { "type": "number", "description": "The principal amount of the agreement."},
            "term": { "type": "number", "description": "The term of the agreement in months."},
            "rate": { "type": "number", "description": "The annual interest rate."}
        }
    },
    "Facility": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Facility",
        "description": "Represents a credit facility granted to a client, often linked to a partner and a specific agreement.",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "agreementId": { "type": "string", "description": "The ID of the lending agreement this facility is tied to." },
            "partnerId": { "type": "string", "description": "The ID of the lending partner providing funds for this facility." },
            "limit": { "type": "number", "description": "The maximum amount for this specific facility." },
            "type": { "type": "string", "enum": ["loan", "lease", "factoring", "installment_sale"], "description": "The type of facility provided." },
            "status": { "type": "string", "enum": ["active", "inactive", "pending"], "description": "The status of the facility." }
        }
    },
    "LendingTransaction": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Lending Transaction",
        "description": "A transaction record related to a specific lending agreement.",
        "type": "object",
        "properties": {
            "id": { "type": "string" }
        }
    },
    "Asset": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Asset",
        "description": "An asset belonging to a client.",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "clientId": { "type": "string" },
            "make": { "type": "string" },
            "model": { "type": "string" },
            "year": { "type": "string" },
            "registrationNumber": { "type": "string" },
            "registerNumber": { "type": "string" },
            "vin": { "type": "string" },
            "engineNumber": { "type": "string" },
            "tare": { "type": "string" },
            "gvm": { "type": "string" },
            "titleholder": { "type": "string" },
            "owner": { "type": "string" },
            "firstRegistrationDate": { "type": "string" },
            "classification": { "type": "string" },
            "documents": {
                "type": "object",
                "properties": {
                    "invoice": { "type": "string", "format": "uri" },
                    "rc1": { "type": "string", "format": "uri" },
                    "licenseDisk": { "type": "string", "format": "uri" },
                    "deliveryNote": { "type": "string", "format": "uri" }
                }
            }
        }
    },
    "Security": {
