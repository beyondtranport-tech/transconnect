
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // In a real app, this would check a custom claim set via a backend process.
      // For this context, we identify the admin by a specific email address.
      return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
    }
    
    function isCompanyOwner(companyId) {
        return request.auth != null && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid;
    }

    // --- User Profiles ---
    // Users can read and write their own profile. Admins can read any profile.
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      // Allow any authenticated user to be created via the backend API.
      allow create: if request.auth != null; 
    }
    
    // --- Company Profiles & Subcollections ---
    match /companies/{companyId} {
      // Allow read/update by the owner or an admin.
      allow get, update: if isCompanyOwner(companyId) || isAdmin();
      // Allow admins to list all companies. This is crucial for the /backend/members-list page.
      allow list: if isAdmin();
      // Allow creation by any authenticated user via the backend API.
      allow create: if request.auth != null; 
      
      // --- Company Subcollections (staff, quotes, etc.) ---
      // The company owner or an admin can read and write any document in any subcollection.
      match /{subcollection}/{docId=**} {
        allow read, write: if isCompanyOwner(companyId) || isAdmin();
      }
    }
    
    // --- Collection Group Queries for Admin Backend ---
    // These rules are essential for the admin backend to query across all companies.
    match /{path=**}/staff/{staffId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/walletPayments/{paymentId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/transactions/{transactionId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/quotes/{quoteId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/enquiries/{enquiryId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/shops/{shopId} {
      allow get, list: if isAdmin();
    }

    // --- Public & Global Collections ---

    // Publicly readable collection for approved shops and their products.
    // Only admins can write to this public collection.
    match /shops/{shopId}/{path=**} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Publicly readable collection for membership plans. Admin-only writes.
    match /memberships/{membershipId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    // Publicly readable collection for platform-wide settings. Admin-only writes.
    match /configuration/{configId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Any authenticated user can create a contribution. Admins can read them.
    match /contributions/{contributionId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }
    
    // Admin-only collections for financial records, audit trails, and permissions.
    match /reconciliations/{reconciliationId} { allow read, write: if isAdmin(); }
    match /platformTransactions/{transactionId} { allow read, write: if isAdmin(); }
    match /auditLogs/{logId} { allow read, write: if isAdmin(); }
    match /permissions/{path=**} { allow read, write: if isAdmin(); }
    match /visitors/{visitorId} { allow read, write: if isAdmin(); }
    match /rewards/{rewardId} { allow read, write: if isAdmin(); }
  }
}
