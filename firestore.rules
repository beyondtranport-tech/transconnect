
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Direct email check for the admin user. This is simple and reliable.
      return request.auth.email == 'transconnect@gmail.com';
    }

    function hasValidMemberId(memberId) {
      // Ensure the document ID matches the 'id' field within the document.
      return request.resource.data.id == memberId;
    }

    function isUpdatingAllowedFields() {
      // Defines the exact set of fields a user is allowed to update on their own profile.
      let allowedToUpdate = ['firstName', 'lastName', 'phone', 'companyName'];
      let incomingKeys = request.resource.data.keys();
      // This ensures a user can only update a subset of their own fields.
      return incomingKeys.hasAll(allowedToUpdate) && incomingKeys.size() == allowedToUpdate.size();
    }
    
    function isOwnerUpdatingAllowedFields(memberId) {
        return isOwner(memberId) && isUpdatingAllowedFields();
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    match /members/{memberId} {
      allow get: if isOwner(memberId) || isAdmin();
      allow list: if isSignedIn();
      allow create: if isOwner(memberId) && hasValidMemberId(memberId);
      
      // An admin can update any member document.
      // A regular user can only update a specific subset of their own fields.
      allow update: if isAdmin() || isOwnerUpdatingAllowedFields(memberId);

      allow delete: if isAdmin();
    }

    match /memberships/{membershipId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // Read-only collection for users
    }

    match /contributions/{contributionId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get, list: if isAdmin();
      allow update, delete: if false; // Contributions are immutable
    }
    
     match /financeApplications/{applicationId} {
      // An applicant can get their own application, an admin can get any.
      allow get: if isOwner(resource.data.applicantId) || isAdmin();
      // Only admins can list all applications.
      allow list: if isAdmin();
      // Creation is allowed by the applicant for their own application, or by an admin for any application.
      allow create: if (isOwner(request.resource.data.applicantId)) || isAdmin();
      // Updates are allowed by the applicant or an admin.
      allow update: if isOwner(resource.data.applicantId) || isAdmin();
      // Finance applications should not be deleted.
      allow delete: if false;
    }

    match /transactions/{transactionId} {
      // Members can read transactions where their UID matches the memberId field.
      allow get: if isSignedIn() && (isOwner(resource.data.memberId) || isAdmin());
      // Admins can list all transactions. Regular users can only list their own.
      allow list: if (isSignedIn() && request.query.where.size() > 0 && request.query.where[0][0] == 'memberId' && request.query.where[0][2] == request.auth.uid) || isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /platform_config/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
