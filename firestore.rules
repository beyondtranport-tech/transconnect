/**
 * This ruleset enforces a security model for the TransConnect platform, focusing on
 * strict user data isolation and controlled access to shared platform data. An admin
 * role is implicitly defined for future use, allowing read access to all members.
 *
 * Core Philosophy:
 * The security model is built on user ownership. Each user has exclusive control
 * over their own data. An administrative function can view all members for
 * management purposes, but cannot modify their data through these rules.
 *
 * Data Structure:
 * - /members/{memberId}: Each user's profile data. Document ID matches UID.
 * - /memberships/{membershipId}: Available membership plans.
 *
 * Key Security Decisions:
 * - User Data Isolation: A user can only access their own /members/{memberId} document.
 * - Admin Read Access: A function `isAdmin()` is defined to grant read-only list
 *   access to the entire /members collection for administrative UIs. For this
 *   prototype, it is hardcoded to `true` but should be replaced with a
 *   custom claims check in production.
 * - Read-Only Platform Data: Membership plans are readable by any signed-in user.
 * - Signed-In Access Only: No access is granted to unauthenticated users.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // In a production app, this would check for a custom claim:
    // return request.auth.token.isAdmin == true;
    // For this prototype, we allow any signed-in user to act as an admin for testing.
    function isAdmin() {
        return isSignedIn();
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function hasValidMemberId(memberId) {
      return request.resource.data.id == memberId;
    }

    function isMemberIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Secures a member's profile.
     * @path /members/{memberId}
     */
    match /members/{memberId} {
      // A user can read their own profile.
      allow get: if isOwner(memberId);
      // An admin can list all members for the backend UI.
      allow list: if isAdmin();
      // A new user can create their own profile.
      allow create: if isOwner(memberId) && hasValidMemberId(memberId);
      // A user can update their own profile; ID is immutable.
      allow update: if isExistingOwner(memberId) && isMemberIdImmutable();
      // A user can delete their own profile.
      allow delete: if isExistingOwner(memberId);
    }

    /**
     * @description Allows any authenticated user to read membership plan details.
     * @path /memberships/{membershipId}
     */
    match /memberships/{membershipId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
