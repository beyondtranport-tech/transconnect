
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /members/{memberId} {
      allow get: if request.auth.uid == memberId || request.auth.token.email == 'transconnect@gmail.com';
      allow list: if request.auth.token.email == 'transconnect@gmail.com';
      allow create: if request.auth.uid == memberId;
      allow update: if request.auth.uid == memberId || request.auth.token.email == 'transconnect@gmail.com';
      allow delete: if request.auth.token.email == 'transconnect@gmail.com';
    }

    match /memberships/{membershipId} {
      allow get, list: if request.auth != null;
      allow write: if request.auth.token.email == 'transconnect@gmail.com';
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, list: if request.auth.token.email == 'transconnect@gmail.com';
      allow update, delete: if request.auth.token.email == 'transconnect@gmail.com';
    }
    
     match /financeApplications/{applicationId} {
      allow get: if request.auth.uid == resource.data.applicantId || request.auth.token.email == 'transconnect@gmail.com';
      allow list: if request.auth.token.email == 'transconnect@gmail.com';
      allow create: if request.auth.uid == request.resource.data.applicantId || request.auth.token.email == 'transconnect@gmail.com';
      allow update: if request.auth.uid == resource.data.applicantId || request.auth.token.email == 'transconnect@gmail.com';
      allow delete: if request.auth.token.email == 'transconnect@gmail.com';
    }

    match /transactions/{transactionId} {
        allow get: if request.auth.uid == resource.data.memberId || request.auth.token.email == 'transconnect@gmail.com';
        allow list: if request.auth.token.email == 'transconnect@gmail.com' || (request.query.get('where')[0][0] == 'memberId' && request.query.get('where')[0][2] == request.auth.uid);
        allow create: if request.auth.uid == request.resource.data.memberId || request.auth.token.email == 'transconnect@gmail.com';
        allow update, delete: if request.auth.token.email == 'transconnect@gmail.com';
    }

    match /platform_config/{docId} {
      allow read, write: if request.auth.token.email == 'transconnect@gmail.com';
    }
  }
}
