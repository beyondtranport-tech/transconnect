
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Admin Override ---
    // This rule grants the specific admin user (beyondtransport@gmail.com)
    // unconditional read/write access to the entire database. It must be at the top.
    match /{path=**} {
      allow read, write: if request.auth.uid == '4CH2RmdJHUSE5Zqc8kPoaEaqgCW2';
    }

    // --- Member Data Ownership ---
    // A user can manage their own document and all subcollections within it.
    // This single rule correctly handles create, read, update, and delete
    // for a user's own data, including the shop subcollection.
    match /members/{userId}/{path=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow a user to create their own top-level member document on sign-up.
    match /members/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // --- Public & Global Collections ---

    // Anyone can read approved shops from the public /shops collection.
    // Admins have write access via the global override rule.
    match /shops/{shopId}/{path=**} {
      allow get: if get(/databases/$(database)/documents/shops/$(shopId)).data.status == 'approved';
      allow list: if resource.data.status == 'approved';
    }
    
    // Publicly readable collection for membership plans.
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
    }

    // Any authenticated user can create a contribution.
    // Admins can manage them via the global override rule.
    match /contributions/{contributionId} {
      allow create: if request.auth != null;
    }
    
    // Admins can manage all finance applications. Users can create their own.
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
    }
  }
}
