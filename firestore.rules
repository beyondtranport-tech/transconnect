
rules_version = '2';

function isAdmin() {
  return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
}

function isOwner(userId) {
  return request.auth != null && request.auth.uid == userId;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // Member Collection
    // Admin can list all members.
    // Individual users can only read/update/delete their own document.
    match /members/{memberId} {
      allow list: if isAdmin();
      allow read, update, delete: if isOwner(memberId) || isAdmin();
      allow create: if request.auth != null;

      // Subcollections for a member
      match /versions/{versionId} {
        allow read, list, create: if isOwner(memberId) || isAdmin();
      }

      match /staff/{staffId} {
        allow create, read, update, delete, list: if isOwner(memberId) || isAdmin();
      }

      match /transactions/{transactionId} {
        allow create, read, update, delete, list: if isOwner(memberId) || isAdmin();
      }

      match /financeApplications/{applicationId} {
        allow create, read, update, delete, list: if isOwner(memberId) || isAdmin();
      }
      
      // Corrected rule for the 'shops' subcollection
      match /shops/{shopId} {
        allow list, read, write, delete: if isOwner(memberId) || isAdmin();
      }
    }
    
    // Other top-level collections
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null;
      allow read, list, update, delete: if isAdmin();
    }
    
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
       allow read, list, update, delete: if isAdmin();
    }
  }
}
