
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
    }

    function getCompanyId(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.companyId;
    }
    
    // A user can read a company document if they are the owner of that company.
    function isCompanyOwner(companyId) {
        return request.auth != null && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid;
    }

    // --- User Profiles ---
    // A user can create their own profile.
    // A user can only read or update their own profile. Admins can read any profile.
    match /users/{userId} {
      allow create, get, update: if isOwner(userId);
      allow read: if isAdmin();
    }

    // --- Company Profiles ---
    // A user can create a company document.
    // A company document can be read or updated by its owner, or by an admin.
    match /companies/{companyId} {
      allow create: if request.auth != null;
      allow get, update, delete: if isCompanyOwner(companyId) || isAdmin();

      // --- Company Subcollections ---
      // The owner of the parent company has full access to all subcollections. Admins also have full access.
      match /{subcollection}/{docId=**} {
        allow read, write: if isCompanyOwner(companyId) || isAdmin();
      }
    }

    // --- Public & Global Collections ---

    // Publicly readable collection for approved shops and their products.
    // Writes are handled by admin-only backend functions.
    match /shops/{shopId}/{path=**} {
      allow get, list: if true;
    }

    // Publicly readable collection for membership plans.
    // Only the admin can create, update, or delete plans.
    match /memberships/{membershipId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    // Publicly readable collection for platform-wide settings like bank details.
    match /configuration/{configId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Any authenticated user can create a contribution. Read access is for admins.
    match /contributions/{contributionId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }

    // Admin-only collections for financial records
    match /reconciliations/{reconciliationId} {
        allow read, write: if isAdmin();
    }

    match /platformTransactions/{transactionId} {
        allow read, write: if isAdmin();
    }
  }
}
