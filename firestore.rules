
rules_version = '2';
service cloud.firestore {

  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
    }
    
    // Specific rules for individual member documents
    match /members/{memberId} {
      // User can read/update their own document. Admin can read/write any member doc.
      allow get, update: if (request.auth != null && request.auth.uid == memberId) || isAdmin();

      // A user can create their own document.
      allow create: if request.auth != null && request.resource.data.id == request.auth.uid;
      
      // Only admin can delete member documents.
      allow delete: if isAdmin();

      // IMPORTANT: `list` permission is NOT granted here to avoid rule conflicts.
      // It is handled by the broader collection match below.

      match /staff/{staffId} {
        allow read, list, create, update, delete: if request.auth.uid == memberId || isAdmin();
      }

      match /versions/{versionId} {
        allow read, list: if request.auth.uid == memberId || isAdmin();
        allow create: if request.auth.uid == memberId;
        allow update, delete: if false;
      }
      
      match /transactions/{transactionId} {
        allow read, list: if request.auth.uid == memberId || isAdmin();
        allow create: if request.auth.uid == memberId; 
        allow update, delete: if isAdmin();
      }
      
      match /financeApplications/{applicationId} {
        allow get, create, update, delete: if request.auth.uid == memberId || isAdmin();
        allow list: if request.auth.uid == memberId || isAdmin();
      }
    }
    
    // Broad rule for the entire `members` collection, only for the admin's `list` operation.
    // This resolves the conflict with the more specific `get` rule above.
    match /members/{document=**} {
        allow list: if isAdmin();
    }

    match /memberships/{membershipId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin(); 
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, list: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    match /financeApplications/{applicationId} {
      allow read, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /transactions/{transactionId} {
        allow read, write: if isAdmin();
    }

    match /platform_config/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
