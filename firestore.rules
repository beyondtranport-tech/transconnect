
rules_version = '2';

function isAdmin() {
  return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
}

function isOwner(userId) {
  return request.auth != null && request.auth.uid == userId;
}

service cloud.firestore {
  match /databases/{database}/documents {

    match /members/{memberId} {
      allow read, update, delete: if isOwner(memberId) || isAdmin();
      allow create: if request.auth != null; // Any authenticated user can create their own member document

      match /versions/{versionId} {
        allow read, list, create: if isOwner(memberId) || isAdmin();
      }

      match /staff/{staffId} {
        allow read, list, create, update, delete: if isOwner(memberId) || isAdmin();
      }

      match /transactions/{transactionId} {
        allow read, list, create, update, delete: if isOwner(memberId) || isAdmin();
      }

      match /financeApplications/{applicationId} {
        allow read, list, create, update, delete: if isOwner(memberId) || isAdmin();
      }
    }

    // Admin can list all members
    match /members/{memberId} {
        allow list: if isAdmin();
    }
    
    // Other collections
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null;
      allow read, list, update, delete: if isAdmin();
    }
    
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
       allow read, list, update, delete: if isAdmin();
    }
  }
}
