
rules_version = '2';

function isAdmin() {
  return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
}

function isOwner(userId) {
  return request.auth != null && request.auth.uid == userId;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // Member Collection
    // This single rule block is now the source of truth for all member-owned data.
    match /members/{memberId} {
      allow list: if isAdmin();
      allow read, update, delete: if isOwner(memberId) || isAdmin();
      allow create: if request.auth != null;

      // This rule grants the owner of the member document full access to all its subcollections.
      // This is the definitive fix for the recurring subcollection permission errors.
      match /{allSubcollections=**} {
        allow read, write: if isOwner(memberId) || isAdmin();
      }
    }
    
    // Shops collection with Admin Approval flow
    // This top-level collection is now for public viewing of APPROVED shops only.
    // Members no longer write here directly.
    match /shops/{shopId} {
      // Anyone can see approved shops. Admins can see all.
      allow get, list: if resource.data.status == 'approved' || isAdmin();
      
      // Only Admins can create, update, or delete from the top-level public collection.
      allow write: if isAdmin();

      // Products are publicly readable if the parent shop is approved.
      match /products/{productId} {
         allow read: if get(/databases/$(database)/documents/shops/$(shopId)).data.status == 'approved' || isAdmin();
         allow write: if isAdmin();
      }
    }
    
    // Other top-level collections
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null;
      allow read, list, update, delete: if isAdmin();
    }
    
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
       allow read, list, update, delete: if isAdmin();
    }
  }
}
