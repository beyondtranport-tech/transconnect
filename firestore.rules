
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // It's recommended to use custom claims for security and scalability.
      // To set a custom claim, use the Firebase Admin SDK to set {'admin': true} on a user's token.
      let hasAdminClaim = request.auth != null && request.auth.token.admin == true;
      let isSuperAdminByUID = request.auth != null && request.auth.uid == '4CH2RmdJHUSE5Zqc8kPoaEaqgCW2';
      return hasAdminClaim || isSuperAdminByUID;
    }
    
    function isCompanyOwner(companyId) {
        let companyDoc = get(/databases/$(database)/documents/companies/$(companyId)).data;
        // Check both the new ownerId field and the user's own profile for legacy data.
        return companyDoc.ownerId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get, update: if isOwner(userId) || isAdmin();
      allow create: if request.auth != null; // Onboarding via API
      allow list: if isAdmin();
    }
    
    // --- Company Profiles ---
    match /companies/{companyId} {
      allow create: if request.auth != null; 
      allow get, update: if isAdmin() || isCompanyOwner(companyId);
      allow list: if isAdmin();

      // --- Company Subcollections (Direct Access) ---
      match /{subcollection}/{docId=**} {
        allow read, write: if isAdmin() || isCompanyOwner(companyId);
      }
    }
    
    // --- Collection Group Queries for Admin Backend ---
    match /{path=**}/staff/{staffId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/walletPayments/{paymentId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/transactions/{transactionId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/quotes/{quoteId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/enquiries/{enquiryId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/shops/{shopId} {
      allow get, list: if isAdmin();
    }
     match /{path=**}/agreements/{agreementId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/auditLogs/{logId} {
      allow get, list: if isAdmin();
    }

    // --- Public & Global Collections ---
    match /shops/{shopId}/{path=**} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /visitors/{visitorId} {
      allow write: if true;
      allow read: if isAdmin();
    }

    match /memberships/{membershipId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /configuration/{configId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }

    // Admin-only collections
    match /reconciliations/{reconciliationId} {
        allow read, write: if isAdmin();
    }
    match /platformTransactions/{transactionId} {
        allow read, write: if isAdmin();
    }
    match /auditLogs/{logId} {
        allow read, write: if isAdmin();
    }
    match /permissions/{path=**} {
        allow read, write: if isAdmin();
    }
    match /leads/{leadId=**} {
      allow read, write: if isAdmin();
    }
    match /partners/{partnerId} {
      allow read, write: if isAdmin();
    }
  }
}
