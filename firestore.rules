
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Admin Override ---
    // Grant the specific admin user unconditional read/write access to all documents.
    // This is necessary for the admin backend to function correctly.
    match /{path=**} {
      allow read, write: if request.auth.uid == '4CH2RmdJHUSE5Zqc8kPoaEaqgCW2';
    }

    // --- Members Collection ---
    // This rule allows a non-admin user to read and update their OWN document only.
    match /members/{userId} {
       allow get, update: if request.auth != null && request.auth.uid == userId;
       allow create: if request.auth != null; // Allow any authenticated user to create their own member document.
    }

    // Allow members to manage their own subcollections.
    match /members/{userId}/{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }


    // --- Public & Global Collections ---

    // Anyone can read approved shops. Admins can write (covered by global rule).
    match /shops/{shopId} {
      allow get, list: if resource.data.status == 'approved';
    }
    
    // Publicly readable collection for membership plans
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
    }

    // Any authenticated user can create a contribution. Admins can manage them.
    match /contributions/{contributionId} {
      allow create: if request.auth != null;
    }
    
    // Admins can manage all finance applications. Users can create their own.
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
    }
  }
}
