
/**
 * This ruleset enforces a security model for the TransConnect platform, focusing on
 * strict user data isolation and controlled access to shared platform data. An admin
 * role is implicitly defined for future use, allowing read access to all members.
 *
 * Core Philosophy:
 * The security model is built on user ownership. Each user has exclusive control
 * over their own data. An administrative function can view all members for
 * management purposes, but cannot modify their data through these rules.
 *
 * Data Structure:
 * - /members/{memberId}: Each user's profile data. Document ID matches UID.
 * - /memberships/{membershipId}: Available membership plans.
 * - /contributions/{contributionId}: Data submitted by members.
 * - /financeApplications/{applicationId}: Finance applications and credit top-ups.
 *
 * Key Security Decisions:
 * - User Data Isolation: A user can only access their own /members/{memberId} document.
 * - Admin Read/Write Access: A function `isAdmin()` is defined to grant read-only list
 *   access to collections for administrative UIs, and write access for specific admin
 *   tasks like updating reward points. For this prototype, it is hardcoded to `true`.
 * - Read-Only Platform Data: Membership plans are readable by any signed-in user.
 * - Signed-In Access Only: No access is granted to unauthenticated users.
 * - Open Contribution: Any authenticated user can create documents in /contributions.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // In a production app, this would check for a custom claim:
    // return request.auth.token.isAdmin == true;
    // For this prototype, we allow any signed-in user to act as an admin for testing.
    function isAdmin() {
        return isSignedIn();
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function hasValidMemberId(memberId) {
      return request.resource.data.id == memberId;
    }

    function isMemberIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }
    
    function isUpdatingOwnMembershipOrPoints(memberId) {
      let isChangingMembership = request.resource.data.membershipId != resource.data.membershipId;
      let isChangingPoints = request.resource.data.rewardPoints != resource.data.rewardPoints;
      let allowedFields = ['membershipId', 'rewardPoints'];
      let otherFieldsChanged = request.resource.data.diff(resource.data).affectedKeys()
                                .filter(key => ! (key in allowedFields)).size() > 0;
                                
      return isOwner(memberId) && (isChangingMembership || isChangingPoints) && !otherFieldsChanged;
    }
    
    function isUpdatingAllowedFields() {
      let allowedToUpdate = ['firstName', 'lastName', 'phone', 'companyName'];
      let incomingKeys = request.resource.data.keys();
      return incomingKeys.hasAll(allowedToUpdate) && incomingKeys.size() == allowedToUpdate.size();
    }
    
    function isOwnerUpdatingAllowedFields(memberId) {
        return isOwner(memberId) && isUpdatingAllowedFields();
    }
    
    function isCreditTopUp() {
      return request.resource.data.fundingType == 'credit-top-up';
    }
    
    function isAdminManagingCredit() {
        return isAdmin() && request.resource.data.keys().hasAll(['rewardPoints']);
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Secures a member's profile.
     * @path /members/{memberId}
     */
    match /members/{memberId} {
      allow get: if isOwner(memberId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(memberId) && hasValidMemberId(memberId);
      
      // Admins can update rewardPoints. Users can update their own profile fields.
      // Users can use their points to change their membership.
      allow update: if (isAdmin() && isAdminManagingCredit()) || 
                      isOwnerUpdatingAllowedFields(memberId) ||
                      isUpdatingOwnMembershipOrPoints(memberId);

      allow delete: if isExistingOwner(memberId);
    }

    /**
     * @description Allows any authenticated user to read membership plan details.
     * @path /memberships/{membershipId}
     */
    match /memberships/{membershipId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Secures member-submitted fleet data.
     * @path /contributions/{contributionId}
     */
    match /contributions/{contributionId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get, list: if isAdmin();
      allow update, delete: if false;
    }
    
     /**
     * @description Secures finance applications and credit top-ups.
     * @path /financeApplications/{applicationId}
     */
    match /financeApplications/{applicationId} {
      // A user can get their own application, and admins can get any.
      allow get: if isOwner(resource.data.applicantId) || isAdmin();
      // Admins can list all. Users can list ONLY their own applications.
      allow list: if isAdmin() || (isSignedIn() && request.query.get("where.applicantId") == request.auth.uid);
      // An applicant can create their own application or credit request.
      allow create: if isOwner(request.resource.data.applicantId);
      // Status can be updated by admin.
      allow update: if isAdmin();
      // Deletion is not allowed to maintain records.
      allow delete: if false;
    }
  }
}
