
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // This function relies on a custom claim which is not being used in this application.
      // It is kept for reference but isRequestingUserAdmin is the primary method.
      return request.auth.token.admin == true;
    }
    
    // Function to check if the person making the request is an admin by reading their own member doc.
    function isRequestingUserAdmin() {
        return get(/databases/$(database)/documents/members/$(request.auth.uid)).data.admin == true;
    }

    function hasValidMemberId(memberId) {
      // Ensure the document ID matches the 'id' field within the document.
      return request.resource.data.id == memberId;
    }

    function isMemberIdImmutable() {
      // Prevent the 'id' field from being changed after creation.
      return request.resource.data.id == resource.data.id;
    }
    
    function isUpdatingAllowedFields() {
      // Defines the exact set of fields a user is allowed to update on their own profile.
      // Note: This list does NOT include walletBalance, membershipId, or admin status.
      let allowedToUpdate = ['firstName', 'lastName', 'phone', 'companyName'];
      let incomingKeys = request.resource.data.keys();
      // This ensures a user can only update a subset of their own fields.
      return incomingKeys.hasAll(allowedToUpdate) && incomingKeys.size() == allowedToUpdate.size();
    }
    
    function isOwnerUpdatingAllowedFields(memberId) {
        return isOwner(memberId) && isUpdatingAllowedFields();
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    match /members/{memberId} {
      allow get: if isOwner(memberId) || isRequestingUserAdmin();
      allow list: if isRequestingUserAdmin();
      allow create: if isOwner(memberId) && hasValidMemberId(memberId);
      
      // An admin can update any member document.
      // A regular user can only update a specific subset of their own fields.
      allow update: if (isRequestingUserAdmin()) || (isOwner(memberId) && isUpdatingAllowedFields());

      allow delete: if isRequestingUserAdmin();
    }

    match /memberships/{membershipId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // Read-only collection for users
    }

    match /contributions/{contributionId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get, list: if isRequestingUserAdmin();
      allow update, delete: if false; // Contributions are immutable
    }
    
     match /financeApplications/{applicationId} {
      // An applicant can get their own application, an admin can get any.
      allow get: if isOwner(resource.data.applicantId) || isRequestingUserAdmin();
      // Only admins can list all applications.
      allow list: if isRequestingUserAdmin();
      // Creation is allowed by the applicant for their own application, or by an admin for any application.
      allow create: if (isOwner(request.resource.data.applicantId)) || isRequestingUserAdmin();
      // Updates are allowed by the applicant or an admin.
      allow update: if isOwner(resource.data.applicantId) || isRequestingUserAdmin();
      // Finance applications should not be deleted.
      allow delete: if false;
    }

    match /transactions/{transactionId} {
      // Only admins can create, read, or list transactions.
      allow read, list, create: if isRequestingUserAdmin();
      // Transactions are immutable once created.
      allow update, delete: if false;
    }

    match /platform_config/{docId} {
      allow read, write: if isRequestingUserAdmin();
    }
  }
}
