
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // This rule requires a database read. Use with caution to avoid circular dependencies.
      // It is NOT used for platform_config access to prevent loops.
      return isSignedIn() && get(/databases/$(database)/documents/members/$(request.auth.uid)).data.admin == true;
    }

    function hasValidMemberId(memberId) {
      // Ensure the document ID matches the 'id' field within the document.
      return request.resource.data.id == memberId;
    }

    function isMemberIdImmutable() {
      // Prevent the 'id' field from being changed after creation.
      return request.resource.data.id == resource.data.id;
    }
    
    function isUpdatingOwnMembershipOrPoints(memberId) {
      let isChangingMembership = request.resource.data.membershipId != resource.data.membershipId;
      let isChangingPoints = request.resource.data.rewardPoints != resource.data.rewardPoints;
      let isChangingAppIds = request.resource.data.financeApplicationIds != resource.data.financeApplicationIds;
      
      let allowedFields = ['membershipId', 'rewardPoints', 'financeApplicationIds'];
      let otherFieldsChanged = request.resource.data.diff(resource.data).affectedKeys()
                                .filter(key => ! (key in allowedFields)).size() > 0;
                                
      return isOwner(memberId) && (isChangingMembership || isChangingPoints || isChangingAppIds) && !otherFieldsChanged;
    }
    
    function isUpdatingAllowedFields() {
      let allowedToUpdate = ['firstName', 'lastName', 'phone', 'companyName'];
      let incomingKeys = request.resource.data.keys();
      // This is a strict check. For more flexibility, consider `hasAny` or iterating keys.
      return incomingKeys.hasAll(allowedToUpdate) && incomingKeys.size() == allowedToUpdate.size();
    }
    
    function isOwnerUpdatingAllowedFields(memberId) {
        return isOwner(memberId) && isUpdatingAllowedFields();
    }
    
    function isAdminManagingCredit() {
        // Use isAdmin() here as it reads a different collection, avoiding a loop on platform_config
        return isAdmin() && request.resource.data.keys().hasAll(['rewardPoints']);
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    match /members/{memberId} {
      // An owner can always read their own document. An admin can also read it.
      allow get: if isOwner(memberId) || isAdmin();
      // Allow any signed-in user to see the list of members for console functionality.
      allow list: if isAdmin();
      // Allow creation for a new user setting their own doc.
      // Admin creation is now handled by making the user and then an admin updates the flag.
      allow create: if isOwner(memberId) && hasValidMemberId(memberId);
      
      // Allow admins to manage credits, and users to update their own allowed profile fields or specific membership details.
      allow update: if (isAdmin() && isAdminManagingCredit()) || 
                      isOwnerUpdatingAllowedFields(memberId) ||
                      isUpdatingOwnMembershipOrPoints(memberId);

      // Only an admin can delete a member's record. This is a critical rule for the backend functionality.
      allow delete: if isAdmin();
    }

    match /memberships/{membershipId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // Read-only collection for users
    }

    match /contributions/{contributionId} {
      // Users can create contributions for themselves.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Only admins can read the full list of contributions.
      allow get, list: if isAdmin();
      allow update, delete: if false; // Contributions are immutable
    }
    
     match /financeApplications/{applicationId} {
      // The owner of the application or an admin can read it.
      allow get: if isOwner(resource.data.applicantId) || isAdmin();
      // Only admins can list all applications.
      allow list: if isAdmin();
      // A user can create an application for themselves.
      allow create: if isOwner(request.resource.data.applicantId);
      // The owner or an admin can update the application.
      allow update: if isAdmin() || isOwner(resource.data.applicantId);
      allow delete: if false; // Applications should not be deleted.
    }

    match /platform_config/{docId} {
      // Correct rule: Allow access if the user's email is the designated admin email. This breaks the circular dependency.
      allow get, list, create, update, delete: if isSignedIn() && request.auth.token.email == 'transconnect@gmail.com';
    }
  }
}
