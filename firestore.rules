
rules_version = '2';
service cloud.firestore {

  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'transconnect@gmail.com';
    }
    
    match /members/{memberId} {
      allow get, read: if request.auth.uid == memberId || isAdmin();
      allow list: if isAdmin();
      allow create: if request.auth != null && request.resource.data.id == request.auth.uid;
      allow update: if (request.auth != null && request.auth.uid == memberId) || isAdmin();
      allow delete: if isAdmin();

      match /staff/{staffId} {
        allow read, list, create, update, delete: if request.auth.uid == memberId || isAdmin();
      }

      match /versions/{versionId} {
        allow read, list: if request.auth.uid == memberId || isAdmin();
        // Allow creating a version only if the user is updating their own member doc
        allow create: if request.auth.uid == memberId;
        // No updates or deletes to preserve history
        allow update, delete: if false;
      }
    }

    match /memberships/{membershipId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin(); 
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, list: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
     match /financeApplications/{applicationId} {
      allow get: if (request.auth != null && request.auth.uid == resource.data.applicantId) || isAdmin();
      allow list: if isAdmin();
      allow create: if request.auth != null && request.auth.uid == request.resource.data.applicantId;
      allow update: if (request.auth != null && request.auth.uid == resource.data.applicantId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow get: if (request.auth != null && request.auth.uid == resource.data.memberId) || isAdmin();
      allow list: if (request.auth != null && request.query.where.memberId == request.auth.uid) || isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /platform_config/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
