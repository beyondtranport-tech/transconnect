
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Member Data Ownership ---
    // A user can create their own member document on signup.
    // Read/update access is granted to the owner OR the admin.
    match /members/{userId} {
      allow create: if request.auth != null;
      allow get, update, delete: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'beyondtransport@gmail.com');

      // --- Member Subcollection Ownership ---
      // This rule grants access to subcollections if the user is the owner OR the admin.
      match /{subcollection}/{docId=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'beyondtransport@gmail.com');
      }
    }

    // --- Public & Global Collections ---

    // Publicly readable collection for approved shops and their products.
    // The `{path=**}` wildcard makes subcollections like 'products' also readable.
    // Writes are handled by admin-only backend functions.
    match /shops/{shopId}/{path=**} {
      allow get, list: if true;
    }

    // Publicly readable collection for membership plans.
    // Only the admin can create, update, or delete plans.
    match /memberships/{membershipId} {
      allow get, list: if true; // Allow anyone to read plans
      allow write: if request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
    }
    
    // Publicly readable collection for platform-wide settings like bank details.
    match /configuration/{configId} {
      allow get, list: if true;
      allow write: if request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
    }

    // Any authenticated user can create a contribution. Read access is for admins.
    match /contributions/{contributionId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
    }

    // Admin-only collections for financial records
    match /reconciliations/{reconciliationId} {
        allow read, write: if request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
    }

    match /platformTransactions/{transactionId} {
        allow read, write: if request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
    }
  }
}
