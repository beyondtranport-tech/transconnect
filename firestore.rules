
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isCompanyOwner(companyId) {
        let companyData = get(/databases/$(database)/documents/companies/$(companyId)).data;
        return request.auth != null && request.auth.uid == companyData.ownerId;
    }
    
    function isAdmin() {
      // In a real app, this would check a custom claim, not an email address.
      return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
    }

    // --- User Profiles ---
    // A user can create their own profile during sign-up.
    // A user can only read or update their own profile document.
    match /users/{userId} {
      allow read, update: if isOwner(userId);
      allow create: if request.auth != null; // Onboarding via API
      allow list: if isAdmin();
    }
    
    // --- Company Profiles ---
    // A user can create a company document (via backend function).
    // A user can read or update their own company document. Admins have full access.
    match /companies/{companyId} {
      allow create: if request.auth != null; // Controlled by backend function
      allow get: if isCompanyOwner(companyId) || isAdmin();
      allow update: if isCompanyOwner(companyId);
      allow list: if isAdmin();

      // --- Staff Management ---
      // The company owner can manage their own staff members.
      match /staff/{staffId} {
        allow read, write, list: if isCompanyOwner(companyId) || isAdmin();
      }

      // --- Other Company Subcollections ---
      // The owner of the parent company document has full access to other subcollections.
      match /{subcollection}/{docId} {
        // This rule applies to quotes, enquiries, walletPayments, transactions, shops, etc.
        // It intentionally does NOT match /staff/{staffId} which has its own rule above.
        allow read, write: if isCompanyOwner(companyId) || isAdmin();
      }
    }


    // --- Public & Global Collections ---

    // Publicly readable collection for approved shops and their products.
    // Writes are handled by admin-only backend functions.
    match /shops/{shopId}/{path=**} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    // Anyone can create (to log their visit), but only admins can read.
    match /visitors/{visitorId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // Publicly readable collection for membership plans.
    // Only the admin can create, update, or delete plans.
    match /memberships/{membershipId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    // Publicly readable collection for platform-wide settings like bank details.
    match /configuration/{configId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Any authenticated user can create a contribution. Read access is for admins.
    match /contributions/{contributionId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }

    // Admin-only collections for financial records
    match /reconciliations/{reconciliationId} {
        allow read, write: if isAdmin();
    }

    match /platformTransactions/{transactionId} {
        allow read, write: if isAdmin();
    }
  }
}
