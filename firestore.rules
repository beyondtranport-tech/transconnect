
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // In a real app, this would check a custom claim.
      return request.auth != null && (request.auth.token.email == 'beyondtransport@gmail.com' || request.auth.token.email == 'mkoton100@gmail.com');
    }
    
    function isCompanyOwner(companyId) {
        let companyDoc = get(/databases/$(database)/documents/companies/$(companyId)).data;
        // Check both the new ownerId field and the user's own profile for legacy data.
        return companyDoc.ownerId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }

    // --- User Profiles ---
    // A user can read/update their own profile. Admins can read/list all profiles.
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if request.auth != null; // Onboarding via API
      allow list: if isAdmin();
    }
    
    // --- Company Profiles ---
    match /companies/{companyId} {
      // Allow creation by any authenticated user via the backend API.
      allow create: if request.auth != null; 
      
      // Allow a user to GET/UPDATE their own company document. Admins have full access.
      allow get, update: if isAdmin() || isCompanyOwner(companyId);
      
      // Allow an admin to LIST all companies. User queries are handled by the secure backend API.
      allow list: if isAdmin();

      // --- Company Subcollections (Direct Access) ---
      // The company owner and admins have full access to all subcollections (staff, wallet, etc.).
      match /{subcollection}/{docId=**} {
        allow read, write: if isAdmin() || isCompanyOwner(companyId);
      }
    }
    
    // --- Collection Group Queries for Admin Backend ---
    match /{path=**}/staff/{staffId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/walletPayments/{paymentId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/transactions/{transactionId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/quotes/{quoteId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/enquiries/{enquiryId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/shops/{shopId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/auditLogs/{logId} {
      allow get, list: if isAdmin();
    }

    // --- Public & Global Collections ---

    // Publicly readable collection for approved shops and their products.
    // Writes are handled by admin-only backend functions.
    match /shops/{shopId}/{path=**} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    // Anyone can create/update their visitor log. Only admins can read.
    match /visitors/{visitorId} {
      allow write: if true;
      allow read: if isAdmin();
    }

    // Publicly readable collection for membership plans.
    // Only the admin can create, update, or delete plans.
    match /memberships/{membershipId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    // Publicly readable collection for platform-wide settings like bank details.
    match /configuration/{configId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Any authenticated user can create a contribution. Read access is for admins.
    match /contributions/{contributionId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }

    // Admin-only collections for financial records
    match /reconciliations/{reconciliationId} {
        allow read, write: if isAdmin();
    }

    match /platformTransactions/{transactionId} {
        allow read, write: if isAdmin();
    }
    
    // Admin-only collection for audit trails.
    match /auditLogs/{logId} {
        allow read, write: if isAdmin();
    }

    // Admin-only collection for managing platform permissions.
    match /permissions/{path=**} {
        allow read, write: if isAdmin();
    }

    // Admin-managed collection for sales leads.
    match /leads/{leadId} {
      allow read, write: if isAdmin();
    }
  }
}

    