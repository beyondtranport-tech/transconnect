
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // In a real app, this would check a custom claim, not an email address.
      return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
    }

    // --- Member Profiles (Primary Collection) ---
    // A member can create their own document.
    // A member can only read or update their own document. Admins have full access.
    match /members/{memberId} {
      allow create: if isOwner(memberId);
      allow get, update: if isOwner(memberId) || isAdmin();
      allow list: if isAdmin(); // Only admins can list all members

      // --- Member Subcollections ---
      // The owner of the parent member document has full access to all subcollections. Admins also have full access.
      match /{subcollection}/{docId=**} {
        allow read, write: if isOwner(memberId) || isAdmin();
      }
    }

    // --- Public & Global Collections ---

    // Publicly readable collection for approved shops and their products.
    // Writes are handled by admin-only backend functions.
    match /shops/{shopId}/{path=**} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    // Simple collection to log unique visitors.
    // Anyone can create (to log their visit), but only admins can read.
    match /visitors/{visitorId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // Publicly readable collection for membership plans.
    // Only the admin can create, update, or delete plans.
    match /memberships/{membershipId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    // Publicly readable collection for platform-wide settings like bank details.
    match /configuration/{configId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Any authenticated user can create a contribution. Read access is for admins.
    match /contributions/{contributionId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }

    // Admin-only collections for financial records
    match /reconciliations/{reconciliationId} {
        allow read, write: if isAdmin();
    }

    match /platformTransactions/{transactionId} {
        allow read, write: if isAdmin();
    }
  }
}
