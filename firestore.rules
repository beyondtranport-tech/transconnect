
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      // Use the email address for admin check as custom claims are not working.
      return request.auth != null && request.auth.token.email == 'transconnect@gmail.com';
    }
    
    match /members/{memberId} {
      allow get: if request.auth != null && (request.auth.uid == memberId || isAdmin());
      allow list: if isAdmin();
      allow create: if request.auth != null && request.auth.uid == memberId;
      allow update: if (request.auth != null && request.auth.uid == memberId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /memberships/{membershipId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin(); 
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, list: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
     match /financeApplications/{applicationId} {
      allow get: if (request.auth != null && request.auth.uid == resource.data.applicantId) || isAdmin();
      allow list: if isAdmin();
      allow create: if request.auth != null && request.auth.uid == request.resource.data.applicantId;
      allow update: if (request.auth != null && request.auth.uid == resource.data.applicantId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow get: if (request.auth != null && request.auth.uid == resource.data.memberId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.memberId != null;
      allow update, delete: if isAdmin();
    }

    match /platform_config/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
