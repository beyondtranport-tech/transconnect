
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Admin Override ---
    // This rule grants the specific admin user (beyondtransport@gmail.com)
    // unconditional read/write access to the entire database. It must be at the top.
    match /{path=**} {
      allow read, write: if request.auth.uid == '4CH2RmdJHUSE5Zqc8kPoaEaqgCW2';
    }

    // TEMPORARY DIAGNOSTIC RULE: Allow any authenticated user to write anywhere.
    // This is INSECURE and will be replaced immediately after the test.
    match /{path=**} {
      allow write: if request.auth != null;
    }

    // --- Public & Global Collections ---

    // Anyone can read approved shops from the public /shops collection.
    // Admins have write access via the global override rule.
    match /shops/{shopId}/{path=**} {
      allow get: if get(/databases/$(database)/documents/shops/$(shopId)).data.status == 'approved';
      allow list: if resource.data.status == 'approved';
    }
    
    // Publicly readable collection for membership plans.
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
    }
  }
}
