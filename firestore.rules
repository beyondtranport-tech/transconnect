
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Admin Override ---
    // This rule grants the specific admin user unconditional access. It must be at the top.
    match /{path=**} {
      allow read, write: if request.auth.uid == '4CH2RmdJHUSE5Zqc8kPoaEaqgCW2';
    }

    // --- Member Data Ownership ---
    // A user can create their own member document upon sign-up.
    // A user can read or update their own top-level member document.
    match /members/{userId} {
      allow create: if request.auth != null;
      allow get, update: if request.auth != null && request.auth.uid == userId;
    }

    // --- Member Subcollection Ownership ---
    // A user has full control over all documents in all of their own subcollections.
    // This rule is recursive and covers create, read, update, and delete for shops, transactions, etc.
    match /members/{userId}/{subcollection}/{docId=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Public & Global Collections ---

    // Anyone can read approved shops from the public /shops collection.
    // Admins have write access via the global override rule.
    match /shops/{shopId}/{path=**} {
      allow get, list: if resource.data.status == 'approved';
    }

    // Publicly readable collection for membership plans.
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
    }

    // Any authenticated user can create a contribution.
    match /contributions/{contributionId} {
      allow create: if request.auth != null;
    }

    // This top-level collection is for admin use.
    // Users create applications in their own subcollection.
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
    }
  }
}
