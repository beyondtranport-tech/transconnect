
rules_version = '2';

function isAdmin() {
  return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
}

function isOwner(userId) {
  return request.auth != null && request.auth.uid == userId;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // This rule manages access to the member document itself.
    // It allows an owner or an admin to read/update/delete their own profile.
    match /members/{memberId} {
      allow get, update, delete: if isOwner(memberId) || isAdmin();
      allow create: if request.auth != null && request.resource.id == request.auth.uid;
      allow list: if isAdmin();

      // This is the explicit rule for the shops subcollection that was failing.
      // By nesting it here, we make it absolutely clear that it is tied to the memberId.
      match /shops/{shopId} {
        allow read, write: if isOwner(memberId) || isAdmin();
      }

      // This is the definitive rule for all OTHER member-owned data in subcollections.
      // It grants the owner or an admin full access to everything else under their member document.
      match /{allOtherPaths=**} {
         allow read, write: if isOwner(memberId) || isAdmin();
      }
    }
    
    // Public, read-only copy of approved shops
    match /shops/{shopId} {
      // Anyone can read approved shops
      allow get, list: if resource.data.status == 'approved' || isAdmin();
      // Only admins can create/update the public shop list
      allow write: if isAdmin(); 
    }
    
    // Publicly readable collection for membership plans
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Collection for anonymous contributions
    match /contributions/{contributionId} {
      allow create: if request.auth != null; // Any authenticated user can contribute
      allow read, list, update, delete: if isAdmin(); // Only admins can manage them
    }
    
    // Top-level collection for finance applications, mainly for admin use
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
       allow read, list, update, delete: if isAdmin();
    }
  }
}
