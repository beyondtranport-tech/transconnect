
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files.
    // This is necessary for generated images to be displayed in the app.
    match /{allPaths=**} {
      allow read;
    }

    // Allow authenticated users to write only to their own designated folder.
    match /user-assets/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
