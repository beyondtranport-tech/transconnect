
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow users to read any file. 
    // This is useful for public product images.
    match /{allPaths=**} {
      allow read;
    }
    
    // Only allow an authenticated user to write to their own folder.
    // The path ensures that a user can only write to a folder that is named with their UID.
    // Example: /products/{userId}/{productId}/{fileName}
    match /products/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
