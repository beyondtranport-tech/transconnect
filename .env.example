# Public environment variables. These are safe to commit to version control.
# Copy this file to .env and fill in the values.

# For AI Features (Google AI Studio) - See docs/gemini-api-key-setup.md
GEMINI_API_KEY=

# For Google Custom Search API (Lead Agent) - See docs/google-search-setup.md
GOOGLE_SEARCH_API_KEY=
CUSTOM_SEARCH_ENGINE_ID=

# For Google Analytics - See docs/google-analytics-setup.md
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
