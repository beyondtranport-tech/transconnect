
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth.token.email == 'transconnect@gmail.com';
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    
    match /members/{memberId} {
      allow get: if isOwner(memberId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(memberId);
      allow update: if isOwner(memberId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /memberships/{membershipId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin(); 
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, list: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
     match /financeApplications/{applicationId} {
      allow get: if isOwner(resource.data.applicantId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(request.resource.data.applicantId) || isAdmin();
      allow update: if isOwner(resource.data.applicantId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow list: if request.auth.token.email == 'transconnect@gmail.com';
      allow get: if isOwner(resource.data.memberId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /platform_config/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
