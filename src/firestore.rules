
rules_version = '2';

function isAdmin() {
  return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
}

function isOwner(userId) {
  return request.auth != null && request.auth.uid == userId;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // This single rule block grants a user full read/write access to their own document and ALL nested subcollections.
    // This is the definitive rule for all member-owned data.
    match /members/{memberId}/{allPaths=**} {
      allow read, write: if isOwner(memberId) || isAdmin();
    }
    
    // This rule allows any authenticated user to create their own member document,
    // and allows admins to list all members.
    match /members/{memberId} {
      allow create: if request.auth != null && request.resource.id == request.auth.uid;
      allow list: if isAdmin();
    }

    // Public, read-only copy of approved shops
    match /shops/{shopId} {
      allow get, list: if resource.data.status == 'approved' || isAdmin();
      allow write: if isAdmin(); // Only admins can write to the public collection

      match /products/{productId} {
         allow get, list: if get(/databases/$(database)/documents/shops/$(shopId)).data.status == 'approved' || isAdmin();
         allow write: if isAdmin();
      }
    }
    
    // Publicly readable collection for membership plans
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Collection for anonymous contributions
    match /contributions/{contributionId} {
      allow create: if request.auth != null; // Any authenticated user can contribute
      allow read, list, update, delete: if isAdmin(); // Only admins can manage them
    }
    
    // Top-level collection for finance applications, mainly for admin use
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
       allow read, list, update, delete: if isAdmin();
    }
  }
}
