
rules_version = '2';
service cloud.firestore {

  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'transconnect@gmail.com';
    }
    
    match /members/{memberId} {
      // Granting `read` access (which includes `get`) to the owner is required to allow them
      // to list documents in their own subcollections. `list` on the `members`
      // collection itself is still correctly restricted to admins.
      allow get: if request.auth.uid == memberId || isAdmin();
      allow create: if request.auth != null && request.resource.data.id == request.auth.uid;
      allow update: if (request.auth != null && request.auth.uid == memberId) || isAdmin();
      allow delete: if isAdmin();

      match /staff/{staffId} {
        allow read, list, create, update, delete: if request.auth.uid == memberId || isAdmin();
      }

      match /versions/{versionId} {
        allow read, list: if request.auth.uid == memberId || isAdmin();
        allow create: if request.auth.uid == memberId;
        allow update, delete: if false;
      }
      
      match /transactions/{transactionId} {
        allow read, list: if request.auth.uid == memberId || isAdmin();
        allow create, update, delete: if isAdmin();
      }
      
      match /financeApplications/{applicationId} {
        // Explicitly grant list permission to the owning user
        allow list: if request.auth.uid == memberId || isAdmin();
        allow get, create, update, delete: if request.auth.uid == memberId || isAdmin();
      }
    }

    match /memberships/{membershipId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin(); 
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, list: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    match /financeApplications/{applicationId} {
      // This top-level collection is now only for admins to list.
      // User-specific queries were causing permission errors.
      allow read, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /transactions/{transactionId} {
        allow read, write: if isAdmin();
    }

    match /platform_config/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
