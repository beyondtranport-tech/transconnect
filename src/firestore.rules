
rules_version = '2';

function isAdmin() {
  return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
}

function isOwner(userId) {
  return request.auth != null && request.auth.uid == userId;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // Member Collection
    match /members/{memberId} {
      allow list: if isAdmin();
      allow read, update, delete: if isOwner(memberId) || isAdmin();
      allow create: if request.auth != null;

      // This rule grants the owner of the member document full access to all its subcollections.
      match /{allSubcollections=**} {
        allow read, write: if isOwner(memberId) || isAdmin();
      }
    }
    
    // Shops collection with Admin Approval flow
    match /shops/{shopId} {
      // Public can read approved shops, owner can read their own regardless of status.
      allow get: if (resource.data.status == 'approved') || 
                   (request.auth != null && request.auth.uid == resource.data.ownerId) ||
                   isAdmin();
      
      // Public can list approved shops. Admins can list all shops.
      allow list: if isAdmin();

      // A user can create a shop, but must set themselves as owner and status to draft
      allow create: if request.auth != null 
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.status == 'draft';
      
      // Owner can update their shop, but cannot approve it themselves. Admin can update anything.
      allow update: if (isOwner(resource.data.ownerId) && request.resource.data.status != 'approved') || isAdmin();

      // Products subcollection
      match /products/{productId} {
         // Owner of the shop has full control over their products
         allow read, write, delete: if isOwner(get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId) || isAdmin();
      }
    }
    
    // Other top-level collections
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null;
      allow read, list, update, delete: if isAdmin();
    }
    
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
       allow read, list, update, delete: if isAdmin();
    }
  }
}
