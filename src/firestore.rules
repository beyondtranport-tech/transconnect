
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Admin Override ---
    // This rule grants the specific admin user (beyondtransport@gmail.com)
    // unconditional read/write access to the entire database. It must be at the top.
    match /{path=**} {
      allow read, write: if request.auth.uid == '4CH2RmdJHUSE5Zqc8kPoaEaqgCW2';
    }

    // --- Members Collection ---
    // A user can create their own member document.
    // A user can only get or update their OWN document.
    match /members/{userId} {
       allow get, update: if request.auth != null && request.auth.uid == userId;
       allow create: if request.auth != null;
    }

    // Allow members to fully manage their own subcollections (e.g., shops, transactions, etc.).
    // This recursive wildcard is crucial for granting permissions to list, read, update, and delete.
    // An explicit 'create' is added to ensure document creation is permitted.
    match /members/{userId}/{subcollection}/{docId=**} {
        allow create, read, update, delete: if request.auth != null && request.auth.uid == userId;
    }


    // --- Public & Global Collections ---

    // Anyone can read approved shops from the public /shops collection.
    // Admins have write access via the global override rule.
    match /shops/{shopId} {
      allow get, list: if resource.data.status == 'approved';
    }
    
    // Publicly readable collection for membership plans.
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
    }

    // Any authenticated user can create a contribution.
    // Admins can manage them via the global override rule.
    match /contributions/{contributionId} {
      allow create: if request.auth != null;
    }
    
    // Admins can manage all finance applications. Users can create their own.
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
    }
  }
}
