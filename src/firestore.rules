
rules_version = '2';

// --- Helper Functions ---
function isAdmin() {
  return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
}

// Check if the requesting user is the owner of the company account.
// It reads the `ownerId` field from the member document.
function isCompanyOwner(memberId) {
  return request.auth != null && get(/databases/$(database)/documents/members/$(memberId)).data.ownerId == request.auth.uid;
}

// --- Service Rules ---
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Members Collection ---

    // Rules for the collection itself
    match /members {
      // Only admins are allowed to list all member documents.
      allow list: if isAdmin();
      
      // Any authenticated user can create their own member document,
      // as long as they set themselves as the owner.
      // This is placed here because create acts on the collection.
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
    }

    // Rules for individual /members/{memberId} documents.
    match /members/{memberId} {
      // An admin can read any member document. The company owner can read their own.
      allow get: if isAdmin() || isCompanyOwner(memberId);
      
      // The company owner or an admin can update their document.
      allow update: if isAdmin() || isCompanyOwner(memberId);
      
      // Only an admin can delete a member document.
      allow delete: if isAdmin();
    }

    // This is the definitive recursive rule for all member-owned subcollections.
    // It grants the company owner or an admin full read/write access to everything
    // underneath the /members/{memberId} document (e.g., shops, transactions, staff).
    match /members/{memberId}/{allPaths=**} {
      allow read, write: if isAdmin() || isCompanyOwner(memberId);
    }
    
    // --- Public & Global Collections ---

    // Public, read-only copy of approved shops
    match /shops/{shopId} {
      // Anyone can read approved shops, but admins can see all.
      allow get, list: if resource.data.status == 'approved' || isAdmin();
      // Only admins can create/update the public shop list (done by a backend function).
      allow write: if isAdmin(); 
    }
    
    // Publicly readable collection for membership plans
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Collection for anonymous contributions
    match /contributions/{contributionId} {
      allow create: if request.auth != null; // Any authenticated user can contribute.
      allow read, list, update, delete: if isAdmin(); // Only admins can manage them.
    }
    
    // Top-level collection for finance applications, mainly for admin use
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
       allow read, list, update, delete: if isAdmin();
    }
  }
}
