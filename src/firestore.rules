
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Admin Override ---
    // Grants the specific admin user unconditional read/write access to the entire database.
    match /{path=**} {
      allow read, write: if request.auth.uid == '4CH2RmdJHUSE5Zqc8kPoaEaqgCW2';
    }

    // --- Member Data Ownership ---
    // A user can manage their own member document and all documents within all of its subcollections.
    // This recursive rule is the key to allowing operations like creating a shop in a subcollection.
    match /members/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Member Creation ---
    // A new user needs to be able to create their own top-level member document.
    match /members/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
    }


    // --- Public & Global Collections ---

    // Anyone can read approved shops from the public /shops collection.
    match /shops/{shopId} {
      allow get, list: if resource.data.status == 'approved';
    }

    // Publicly readable collection for membership plans.
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
    }

    // Any authenticated user can create a contribution.
    match /contributions/{contributionId} {
      allow create: if request.auth != null;
    }

    // Admins can manage all finance applications. Users create their own.
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
    }
  }
}
