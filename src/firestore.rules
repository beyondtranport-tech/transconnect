
rules_version = '2';

function isAdmin() {
  return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
}

function isOwner(userId) {
  return request.auth != null && request.auth.uid == userId;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // This single rule block is the definitive source of truth for all member-owned data.
    // It grants the owner full access to their document and ALL subcollections recursively.
    match /members/{memberId}/{allPaths=**} {
      allow read, write: if isOwner(memberId) || isAdmin();
    }
    
    // Member collection top-level rules
    match /members/{memberId} {
      allow list: if isAdmin();
      allow create: if request.auth != null;
    }

    // Public, read-only copy of approved shops
    match /shops/{shopId} {
      allow get, list: if resource.data.status == 'approved' || isAdmin();
      allow write: if isAdmin();

      match /products/{productId} {
         allow get, list: if get(/databases/$(database)/documents/shops/$(shopId)).data.status == 'approved' || isAdmin();
         allow write: if isAdmin();
      }
    }
    
    // Other top-level collections
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null;
      allow read, list, update, delete: if isAdmin();
    }
    
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
       allow read, list, update, delete: if isAdmin();
    }
  }
}
