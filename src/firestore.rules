
rules_version = '2';

function isAdmin() {
  return request.auth != null && request.auth.token.email == 'beyondtransport@gmail.com';
}

function isOwner(userId) {
  return request.auth != null && request.auth.uid == userId;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // Member Collection
    // This grants an owner full read/write access to their own document and all its subcollections.
    // This is the definitive rule for all member-owned data.
    match /members/{memberId}/{allPaths=**} {
      allow read, write: if isOwner(memberId) || isAdmin();
    }
    
    // Member Collection top-level rules
    match /members/{memberId} {
      allow list: if isAdmin();
      // Allow any authenticated user to create their own member document
      allow create: if request.auth != null && request.auth.uid == memberId;
    }

    // Public, read-only copy of approved shops
    match /shops/{shopId} {
      // Allow public read access only if the shop status is 'approved'
      allow get, list: if resource.data.status == 'approved' || isAdmin();
      // Only admins can create, update, or delete in the public shops collection
      allow write: if isAdmin();

      match /products/{productId} {
         allow get, list: if get(/databases/$(database)/documents/shops/$(shopId)).data.status == 'approved' || isAdmin();
         allow write: if isAdmin();
      }
    }
    
    // Other top-level collections
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null;
      allow read, list, update, delete: if isAdmin();
    }
    
    match /financeApplications/{applicationId} {
       allow create: if request.auth != null;
       allow read, list, update, delete: if isAdmin();
    }
  }
}
