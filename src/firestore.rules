
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'transconnect@gmail.com';
    }
    
    match /members/{memberId} {
      allow get: if isOwner(memberId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(memberId);
      // Admin can update any member document (e.g., wallet balance)
      allow update: if isOwner(memberId) || isAdmin(); 
      allow delete: if isAdmin();
    }

    match /memberships/{membershipId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin(); 
    }

    match /contributions/{contributionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, list: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
     match /financeApplications/{applicationId} {
      allow get: if isOwner(resource.data.applicantId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(request.resource.data.applicantId) || isAdmin();
      allow update: if isOwner(resource.data.applicantId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow get: if isOwner(resource.data.memberId) || isAdmin();
      // Allow admin to list transactions for a specific member, but not all transactions
      allow list: if isAdmin() && request.query.keys().hasAny(['where']) && request.query.where[0][0] == 'memberId';
      allow create: if isAdmin(); // Admin can create manual transactions
      allow update, delete: if isAdmin();
    }

    match /platform_config/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
