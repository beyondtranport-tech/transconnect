
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a single user account in Firebase Authentication.",
      "properties": {
        "id": { "type": "string", "description": "The user's Firebase Auth UID." },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "companyId": { "type": "string", "description": "The ID of the company this user belongs to in the /companies collection." },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "firstName", "lastName", "email", "companyId"]
    },
    "Company": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Company",
      "type": "object",
      "description": "Represents a member's business entity on the TransConnect platform.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the company." },
        "ownerId": { "type": "string", "description": "The Firebase Auth UID of the user who owns and manages this company account." },
        "companyName": { "type": "string", "description": "The registered business name of the company." },
        "registrationNumber": { "type": "string" },
        "vatNumber": { "type": "string" },
        "streetAddress": { "type": "string" },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "postalCode": { "type": "string" },
        "membershipId": { "type": "string", "description": "Reference to Membership tier ID." },
        "membershipStartDate": { "type": "string", "format": "date-time" },
        "billingCycle": { "type": "string", "enum": ["monthly", "annual"] },
        "nextBillingDate": { "type": "string", "format": "date-time" },
        "shopId": { "type": "string", "description": "The ID of the shop owned by this company." },
        "rewardPoints": { "type": "number", "description": "Points earned for community actions." },
        "walletBalance": { "type": "number", "description": "Cash balance in ZAR." },
        "loyaltyTier": { "type": "string", "enum": ["bronze", "silver", "gold"], "description": "The current loyalty status of the member." },
        "activePlans": { "type": "array", "items": { "type": "string" }, "description": "A list of activated Connect plans (e.g., 'loyalty', 'rewards')." },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "ownerId", "companyName", "membershipId"]
    },
    "Shop": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Shop",
      "type": "object",
      "description": "Represents a vendor's shop on the TransConnect platform.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the shop." },
        "ownerId": { "type": "string" },
        "companyId": { "type": "string" },
        "shopName": { "type": "string" },
        "shopDescription": { "type": "string" },
        "category": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "contactPhone": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "pending_review", "approved", "rejected"] },
        "template": { "type": "string" },
        "theme": { "type": "string" },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "heroBannerUrl": { "type": "string" },
        "promotions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "imageUrl": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "ownerId", "companyId", "shopName", "category", "status"]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a single product within a vendor's shop.",
      "properties": {
        "shopId": { "type": "string" },
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "sku": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["shopId", "companyId", "name", "price"]
    },
    "Staff": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Staff",
      "type": "object",
      "description": "Represents a staff member associated with a company.",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "companyId": { "type": "string", "description": "The ID of the parent company this staff member belongs to." },
        "createdAt": { "type": "object" }
      },
      "required": ["firstName", "lastName", "email", "role", "companyId"]
    },
    "Membership": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Membership",
      "type": "object",
      "description": "Represents a single tier of membership plan.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": {
          "type": "object",
          "properties": {
              "monthly": { "type": "number" },
              "annual": { "type": "number" }
          }
        },
        "commissionShare": { "type": "number", "description": "The member's percentage share of earned commissions (e.g., from product sales)." },
        "discountShare": { "type": "number", "description": "The member's percentage share of a negotiated group discount." },
        "features": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "description"]
    },
    "Contribution": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Contribution",
      "type": "object",
      "description": "Represents a single data contribution from a user.",
      "properties": {
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
        "type": { "type": "string", "enum": ["truck", "trailer", "supplier", "client"] },
        "data": { "type": "object" },
        "createdAt": { "type": "object" }
      },
      "required": ["userId", "companyId", "type", "data", "createdAt"]
    },
    "Quote": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Quote",
      "type": "object",
      "description": "Represents a funding quote generated by a user.",
      "properties": {
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
        "fundingType": { "type": "string" },
        "amountRequested": { "type": "number" },
        "details": { "type": "object" },
        "createdAt": { "type": "object" }
      }
    },
    "Enquiry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Enquiry",
      "type": "object",
      "description": "Represents a formal funding enquiry submitted by a user.",
      "properties": {
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
        "status": { "type": "string" },
        "fundingType": { "type": "string" },
        "amountRequested": { "type": "number" },
        "purpose": { "type": "string" },
        "createdAt": { "type": "object" }
      }
    },
    "WalletPayment": {
       "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WalletPayment",
      "type": "object",
      "description": "Represents a pending wallet top-up or membership payment.",
      "properties": {
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "createdAt": { "type": "object" }
      }
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Represents a single financial transaction in the company's wallet ledger.",
      "properties": {
        "transactionId": { "type": "string" },
        "reconciliationId": { "type": "string" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "chartOfAccountsCode": { "type": "string" },
        "status": { "type": "string", "enum": ["pending_allocation", "allocated", "reversal"] },
        "isAdjustment": { "type": "boolean" }
      },
      "required": ["transactionId", "type", "amount", "date", "description", "status"]
    },
    "Reconciliation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Reconciliation",
      "type": "object",
      "description": "Represents a single bank statement reconciliation batch.",
      "properties": {
        "id": { "type": "string" },
        "statementPeriod": { "type": "string" },
        "openingBalance": { "type": "number" },
        "closingBalance": { "type": "number" },
        "status": { "type": "string", "enum": ["in_progress", "completed"] },
        "processedAt": { "type": "object" }
      },
      "required": ["id", "statementPeriod", "openingBalance", "status"]
    },
    "Reward": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Reward",
      "type": "object",
      "description": "A redeemable reward in the loyalty program.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "pointsCost": { "type": "number" },
        "type": { "type": "string", "enum": ["voucher", "discount", "product"] },
        "isActive": { "type": "boolean" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "title", "pointsCost", "type", "isActive"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/entities/User" },
          "description": "Stores individual user profiles. A user can only read/write their own document."
        }
      },
      {
        "path": "/companies/{companyId}",
        "definition": {
          "entityName": "Company",
          "schema": { "$ref": "#/entities/Company" },
          "description": "Stores company profiles. The owner of the company has full read/write access."
        }
      },
      {
        "path": "/companies/{companyId}/staff/{staffId}",
        "definition": {
          "entityName": "Staff",
          "schema": { "$ref": "#/entities/Staff" },
          "description": "Subcollection for company staff members."
        }
      },
      {
        "path": "/companies/{companyId}/quotes/{quoteId}",
        "definition": {
          "entityName": "Quote",
          "schema": { "$ref": "#/entities/Quote" },
          "description": "Subcollection for funding quotes."
        }
      },
      {
        "path": "/companies/{companyId}/enquiries/{enquiryId}",
        "definition": {
          "entityName": "Enquiry",
          "schema": { "$ref": "#/entities/Enquiry" },
          "description": "Subcollection for formal funding enquiries."
        }
      },
      {
        "path": "/companies/{companyId}/walletPayments/{paymentId}",
        "definition": {
          "entityName": "WalletPayment",
          "schema": { "$ref": "#/entities/WalletPayment" },
          "description": "Subcollection for pending wallet payments."
        }
      },
      {
        "path": "/companies/{companyId}/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/entities/Transaction" },
          "description": "Subcollection for wallet transactions."
        }
      },
      {
        "path": "/companies/{companyId}/shops/{shopId}",
        "definition": {
          "entityName": "Shop",
          "schema": { "$ref": "#/entities/Shop" },
          "description": "Subcollection for the shop belonging to a company."
        }
      },
      {
        "path": "/shops/{shopId}",
        "definition": {
          "entityName": "Shop",
          "schema": { "$ref": "#/entities/Shop" },
          "description": "Top-level collection for public, approved shops."
        }
      },
      {
        "path": "/shops/{shopId}/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": { "$ref": "#/entities/Product" },
          "description": "Subcollection for products in a public shop."
        }
      },
      {
        "path": "/memberships/{membershipId}",
        "definition": {
          "entityName": "Membership",
          "schema": { "$ref": "#/entities/Membership" },
          "description": "Public collection for available membership plans."
        }
      },
       {
        "path": "/rewards/{rewardId}",
        "definition": {
          "entityName": "Reward",
          "schema": { "$ref": "#/entities/Reward" },
          "description": "Admin-managed collection of redeemable rewards."
        }
      },
      {
        "path": "/contributions/{contributionId}",
        "definition": {
          "entityName": "Contribution",
          "schema": { "$ref": "#/entities/Contribution" },
          "description": "Stores anonymous data contributions from users."
        }
      },
      {
        "path": "/platformTransactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/entities/Transaction" },
          "description": "Admin-only collection for platform-level expenses."
        }
      },
      {
        "path": "/reconciliations/{reconciliationId}",
        "definition": {
          "entityName": "Reconciliation",
          "schema": { "$ref": "#/entities/Reconciliation" },
          "description": "Admin-only collection for reconciliation batches."
        }
      }
    ],
    "reasoning": "The data model is refactored to separate user identity from business entities. A new `/users` collection stores individual user profiles, linked via Firebase Auth UID. A new `/companies` collection stores business-related data, including wallet balance, membership status, and subcollections for transactions, staff, quotes, etc. This creates a cleaner, more scalable architecture where a user owns a company, rather than the user and company being the same entity. This prevents data duplication and clarifies ownership for security rules."
  }
}
    

    