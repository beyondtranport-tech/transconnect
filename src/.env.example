# Google Custom Search API - Required for the AI Lead Research Agent.
# See docs/google-search-setup.md for instructions.
GOOGLE_SEARCH_API_KEY=''
CUSTOM_SEARCH_ENGINE_ID=''

# Google Analytics - Optional, for tracking user behavior.
# See docs/google-analytics-setup.md for instructions.
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=''
